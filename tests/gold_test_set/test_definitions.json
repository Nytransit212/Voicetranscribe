    {
      "test_id": "phone_call_quality",
      "name": "Compressed Audio Phone Quality",
      "audio_file": "synthetic_phone_call.wav",
      "duration": 30.0,
      "scenario_type": "challenging_audio",
      "description": "Compressed audio simulating phone call quality",
      "expected_metrics": {
