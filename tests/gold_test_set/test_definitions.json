  ],
  "quality_thresholds": {
    "regression_tolerance": {
      "der_increase_max": 0.05,
      "wer_increase_max": 0.05,
      "confidence_decrease_max": 0.1,
      "processing_time_increase_max": 20.0
    },
    "acceptance_criteria": {
      "pass_rate_min": 0.8,
      "critical_scenarios": ["clear_speech_multispeaker", "heavy_overlap_crosstalk"],
      "performance_benchmarks": {
        "baseline_scenarios": {"der_max": 0.15, "wer_max": 0.12},
        "challenging_scenarios": {"der_max": 0.35, "wer_max": 0.35},
        "edge_cases": {"der_max": 0.45, "wer_max": 0.45}
      }
    }
  }
