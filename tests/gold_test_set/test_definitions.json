      "expected_metrics": {
        "der_max": 0.20,
        "wer_max": 0.30,
        "confidence_calibration_min": 0.6,
        "processing_time_max": 70.0,
        "linguistic_coherence_min": 0.7
      },
      "metadata": {
        "speaker_count": 3,
