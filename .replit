modules = ["python-3.11"]
[agent]
integrations = ["python_openai:1.0.0"]

[nix]
channel = "stable-25_05"
packages = ["antlr", "ffmpeg-full", "glibcLocales", "jre", "libiconv", "libjpeg_turbo", "libpng", "libsndfile", "libxcrypt", "libyaml", "pkg-config", "which", "xsimd"]

[deployment]
deploymentTarget = "autoscale"
run = ["streamlit", "run", "app.py", "--server.port", "5000"]

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Ensemble Transcription App"

[[workflows.workflow]]
name = "Ensemble Transcription App"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "streamlit run app.py --server.port 5000"
waitForPort = 5000

[workflows.workflow.metadata]
outputType = "webview"

[[ports]]
localPort = 5000
externalPort = 80

[[ports]]
localPort = 32825
externalPort = 3000

[[ports]]
localPort = 36547
externalPort = 3003

[[ports]]
localPort = 37709
externalPort = 4200

[[ports]]
localPort = 40467
externalPort = 5173

[[ports]]
localPort = 42979
externalPort = 3001

[[ports]]
localPort = 43497
externalPort = 5000

[[ports]]
localPort = 45281
externalPort = 3002
