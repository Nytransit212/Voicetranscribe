# Google Drive Service Account Configuration
# Required for large file upload functionality

# Google Service Account JSON Key (entire JSON as single line)
# Get this from Google Cloud Console -> Service Accounts -> Create Key -> JSON
# Copy the entire JSON content and paste it here as a single line
GOOGLE_SERVICE_ACCOUNT_KEY={"type": "service_account", "project_id": "your-project", "private_key_id": "...", "private_key": "-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n", "client_email": "your-service-account@your-project.iam.gserviceaccount.com", "client_id": "...", "auth_uri": "https://accounts.google.com/o/oauth2/auth", "token_uri": "https://oauth2.googleapis.com/token", "auth_provider_x509_cert_url": "https://www.googleapis.com/oauth2/v1/certs", "client_x509_cert_url": "..."}

# Google Drive Folder ID where files will be uploaded
# Get this from the Google Drive folder URL: https://drive.google.com/drive/folders/YOUR_FOLDER_ID_HERE
# Make sure to share this folder with the service account email address
GOOGLE_DRIVE_FOLDER_ID=your_folder_id_here

# Other existing environment variables (keep these if you have them)
# HUGGINGFACE_TOKEN=your_hf_token_here
# OPENAI_API_KEY=your_openai_key_here
# ASSEMBLYAI_API_KEY=your_assemblyai_key_here